{
    "name": "leons-portfolio",
    "version": "1.0.0",
    "description": "Leon Madara's Portfolio Landing Page - Vanilla HTML/CSS/JavaScript",
    "scripts": {
        "dev": "vite --config vite.react.config.mjs",
        "build": "npm run react:build",
        "react:dev": "vite --config vite.react.config.mjs",
        "react:build": "vite build --config vite.react.config.mjs",
        "react:preview": "vite preview --config vite.react.config.mjs",
        "react:test": "vitest --config vitest.react.config.ts --run",
        "react:typecheck": "tsc --project tsconfig.react.json --noEmit",
        "react:shots": "node validation/contact-screenshots.mjs",
        "serve": "npx serve public -p 3000",
        "start": "npx serve public -p 3000",
        "test:gsap": "jest tests/gsapDemoReference.test.js"
    },
    "keywords": [
        "portfolio",
        "landing-page",
        "html",
        "css",
        "javascript",
        "vanilla"
    ],
    "author": "Leon Madara",
    "license": "MIT",
    "dependencies": {
        "@gsap/react": "^2.1.2",
        "gsap": "^3.13.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-helmet-async": "^3.0.0",
        "react-router-dom": "^7.13.2"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "jest": "^29.0.0",
        "jsdom": "^29.0.1",
        "playwright-core": "^1.59.1",
        "serve": "^14.2.5",
        "typescript": "^6.0.2",
        "vite": "^8.0.3",
        "vitest": "^4.1.2"
    },
    "jest": {
        "modulePathIgnorePatterns": [
            "<rootDir>/ImageNavBar_v5",
            "<rootDir>/Toggle-Switch"
        ]
    },
    "main": "index.js",
    "type": "commonjs"
}
